# ModelBench environment variables
# IMPORTANT: Do NOT prefix any of these with NEXT_PUBLIC_.
# They are server-only and will never be exposed to the browser.

# Server-side secrets (used by /api/* routes)
GROQ_API_KEY=
GROK_API_KEY=
GITHUB_TOKEN=

# Optional defaults — can be overridden in the in-app Settings panel
# Default model to use when judging (e.g. "groq:llama-3.3-70b-versatile" or "grok:grok-3-mini")
DEFAULT_MODEL=groq:llama-3.3-70b-versatile

# GitHub Pages branch (default: gh-pages)
GITHUB_PAGES_BRANCH=gh-pages
